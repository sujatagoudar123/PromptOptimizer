# ============================================================
# LLM Optimization Gateway — environment configuration template
# ------------------------------------------------------------
# Copy this file to .env and adjust. All vars use the LLMGW_ prefix.
# Nothing in this file is a secret by itself — fill in values locally.
# ============================================================

# --- Server ---
LLMGW_HOST=0.0.0.0
LLMGW_PORT=8080
LLMGW_LOG_LEVEL=INFO
LLMGW_ENVIRONMENT=development

# --- Governance ---
LLMGW_MAX_PROMPT_TOKENS=8000
# If true, oversize prompts are rejected with HTTP 413.
# If false, optimizer is given a chance to compress them first.
LLMGW_REJECT_OVERSIZE=false

# --- Optimization ---
LLMGW_OPTIMIZATION_ENABLED=true
LLMGW_COMPRESSION_CONFIDENCE_WARN_THRESHOLD=0.6
# Entropy-based stopword pruning (real token savings on top of filler removal)
LLMGW_AGGRESSIVE_PRUNING=true

# --- Prompt Coaching (quality scoring + rewrite) ---
LLMGW_COACHING_ENABLED=true
# Prompts scoring below this threshold are rewritten into canonical
# markdown sections. Range 0.0-1.0.
LLMGW_PROMPT_QUALITY_THRESHOLD=0.55

# --- Caching ---
# Backends: memory | redis
LLMGW_CACHE_BACKEND=memory
LLMGW_CACHE_TTL_SECONDS=3600
LLMGW_CACHE_MAX_ENTRIES=10000
LLMGW_SEMANTIC_CACHE_ENABLED=true
LLMGW_SEMANTIC_SIMILARITY_THRESHOLD=0.92

# Embedding backends: hashing | openai
LLMGW_EMBEDDING_BACKEND=hashing
LLMGW_EMBEDDING_DIM=256

# --- Providers ---
# Comma-separated chain. First is primary; rest are failover.
# Options: echo, openai
LLMGW_PROVIDER_CHAIN=echo
LLMGW_DEFAULT_MODEL=echo-1

# --- OpenAI (only used when 'openai' is in the chain) ---
# LLMGW_OPENAI_API_KEY=sk-...
LLMGW_OPENAI_BASE_URL=https://api.openai.com/v1
LLMGW_OPENAI_TIMEOUT_SECONDS=30

# --- Redis (only when cache backend is redis) ---
LLMGW_REDIS_URL=redis://localhost:6379/0

# --- Request ---
LLMGW_REQUEST_TIMEOUT_SECONDS=60
